rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Produtos — leitura pública, escrita só admin
    match /products/{productId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // Clientes / usuários
    match /users/{userId} {
      allow read: if isAdmin() || (request.auth != null && userId == request.auth.uid);
      allow create: if request.auth != null && userId == request.auth.uid;
      allow update: if isAdmin() || (request.auth != null && userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Pedidos
    match /orders/{orderId} {
      allow read: if isAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid)
        || (request.auth != null && resource.data.customerEmail == request.auth.token.email);
      allow create: if (request.auth != null || request.resource.data.get('customerType', '') == 'guest')
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll(['totalAmount', 'items', 'customerEmail'])
        && request.resource.data.totalAmount > 0
        && request.resource.data.items.size() > 0;
      allow update: if isAdmin()
        || (request.auth != null
            && resource.data.customerEmail == request.auth.token.email
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
            && request.resource.data.status == 'delivered');
      allow delete: if isAdmin();
    }

    // Administradores
    match /admins/{adminId} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // Settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Analytics de visitantes
    match /analytics_daily/{dateKey} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }
    match /analytics_pages/{pageId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }
    match /analytics_products/{productId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }
  }
}
